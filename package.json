{
  "name": "kodhub-design",
  "private": true,
  "version": "0.0.0",
  "description": "Kodhub Design — task-centric creative work management for Middle East agencies.",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": "25.6.1",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  }
}
